DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumina_health

# ─── Server ──────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── App ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
